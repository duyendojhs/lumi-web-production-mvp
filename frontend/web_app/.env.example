# App
APP_ENV=development
# Set this to the deployed origin in production, for example https://your-domain.example
NEXT_PUBLIC_APP_URL=
DATA_ROOT=

# Gemini server-side only. Do not expose this with NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# Database
DATABASE_URL=
DATABASE_SSL=
DATABASE_POOL_MAX=5

# Auth
AUTH_PROVIDER=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AUTH_ADMIN_EMAILS=
# Local-only demo endpoint. Keep APP_DEMO_MODE=false in production.
APP_DEMO_MODE=false
APP_DEMO_USER_EMAIL=demo@example.com
APP_DEMO_USER_PASSWORD=demo123456

# Object storage
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=lumi-data
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Background jobs
JOB_PROVIDER=manual
QSTASH_TOKEN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vector search
VECTOR_PROVIDER=pgvector
QDRANT_URL=
QDRANT_API_KEY=

# Monitoring
SENTRY_DSN=
